{
  "name": "creativlab-attendance",
  "version": "1.0.1",
  "description": "CreativLab Attendance – native wrapper for Android and Windows",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:win:portable": "electron-builder --win portable",
    "release": "electron-builder --win --x64 --publish always",
    "android:setup": "npx cap add android && npx cap sync android",
    "android:sync": "npx cap sync android",
    "android:run": "npx cap run android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.61.1"
  },
  "build": {
    "appId": "com.creativlab.attendance",
    "productName": "CreativLab Attendance",
    "directories": {
      "output": "dist-win"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "config.json"
    ],
    "extraResources": [
      {
        "from": "attendance-app",
        "to": "attendance-app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signtoolOptions": {
        "certificateFile": "electron/icons/codesign.pfx",
        "certificatePassword": "cl-sign-2024"
      },
      "icon": "electron/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CreativLab Attendance",
      "artifactName": "CreativLab-Attendance-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "mdakashhossain1",
      "repo": "creativlab",
      "releaseType": "release"
    }
  }
}
